# ProbeMap — environment variables
# Copy: cp .env.example .env  — затем правьте `.env` (файл в git не попадает).
#
# Docker Compose подхватывает `.env` из каталога с `docker-compose.yml` для подстановки
# ${VAR} в compose и для переменных ниже.

# Directory for persistent data (config, projects, layouts, icons).
# Default: ./data (relative to repo root).
# In Docker: /app/data (mount as volume).
# PROBEMAP_DATA_DIR=./data

# Directory with built frontend (index.html + assets).
# If set and directory exists, FastAPI serves it on /.
# In Docker: /app/static
# In dev: leave unset — Vite dev server handles frontend.
# PROBEMAP_STATIC_DIR=

# HTTP port for uvicorn (внутри контейнера; в образе по умолчанию 8000).
# PROBEMAP_PORT=8000

# Порт на хосте при `docker compose up` (маппинг host:container → PROBEMAP_HOST_PORT:8000).
# PROBEMAP_HOST_PORT=8000

# Allowed CORS origins (comma-separated). Use * for development.
# PROBEMAP_CORS_ORIGINS=*

# VictoriaMetrics / Prometheus URL override.
# If set, takes precedence over the URL saved in config.json.
# PROBEMAP_DATASOURCE_URL=https://victoriametrics.example.com

# Log level (debug, info, warning, error).
# PROBEMAP_LOG_LEVEL=info

# Admin password for write operations (PUT/POST/DELETE).
# If not set — all requests are allowed (single-user / trusted-network mode).
# If set — write endpoints require a Bearer token obtained via POST /api/auth/login.
# PROBEMAP_ADMIN_PASSWORD=changeme
