# ProbeMap — environment variables
# Copy: cp .env.example .env  — then edit `.env` (not committed to git).
#
# Docker Compose reads `.env` from the directory containing `docker-compose.yml`
# for ${VAR} substitution in the compose file and for passing variables to the container.

# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------

# Directory for persistent data (config, projects, layouts, icons).
# In Docker: /app/data (mounted as a volume).
# PROBEMAP_DATA_DIR=./data

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# Directory with the built frontend (index.html + assets).
# In Docker: /app/static. In dev mode: leave unset — Vite handles it.
# PROBEMAP_STATIC_DIR=

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# HTTP port for uvicorn inside the container.
# PROBEMAP_PORT=8000

# Host port for `docker compose up` (host:container mapping).
# PROBEMAP_HOST_PORT=8000

# Allowed CORS origins (comma-separated). Use * for dev / trusted networks.
# PROBEMAP_CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Datasource
# ---------------------------------------------------------------------------

# VictoriaMetrics / Prometheus URL. If set, takes precedence over config.json.
# PROBEMAP_DATASOURCE_URL=https://victoriametrics.example.com

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: debug | info | warning | error.
# PROBEMAP_LOG_LEVEL=info

# Log format: json | text | "" (auto: text on TTY, json otherwise).
# PROBEMAP_LOG_FORMAT=

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Admin password for write operations (PUT/POST/DELETE).
# Not set — all requests allowed (single-user / trusted-network mode).
# Set — write endpoints require a Bearer token from POST /api/auth/login.
# PROBEMAP_ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# S3-compatible storage (optional)
# ---------------------------------------------------------------------------

# When configured, all data (config, projects, layouts, icons) is stored in S3.
# When not configured, falls back to local PROBEMAP_DATA_DIR.
# PROBEMAP_S3_ENDPOINT=https://s3.amazonaws.com
# PROBEMAP_S3_BUCKET=probemap
# PROBEMAP_S3_ACCESS_KEY=
# PROBEMAP_S3_SECRET_KEY=
# PROBEMAP_S3_REGION=us-east-1
# PROBEMAP_S3_PREFIX=          # optional key prefix inside the bucket
